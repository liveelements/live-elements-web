{
    "name": "live-elements-web-source",
    "version": "0.1.15",
    "description": "Live Elements for the web.",
    "private": "true",
    "lvweb": {
        "bundle": "live-elements-web-cli/templates/bundles/demo/demo.lv",
        "allowBundleView": true
    },
    "scripts": {
        "test": "vitest run --config vitest.config.mjs",
        "test:watch": "vitest --config vitest.config.mjs",
        "build": "webpack",
        "start": "webpack-dev-server --port 8080",
        "bootstrap": "npx lerna bootstrap --hoist",
        "update-version": "npx lerna exec -- npm version"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "lerna": "^8.0.0",
        "tape": "^5.5.3",
        "vitest": "^1.6.0"
    },
    "dependencies": {
        "live-elements-core": "file:packages/live-elements-core",
        "live-elements-js-compiler": "^0.1.20",
        "live-elements-loader": "file:packages/live-elements-loader",
        "live-elements-web-cli": "file:packages/live-elements-web-cli",
        "live-elements-web-server": "file:packages/live-elements-web-server",
        "live-testspec": "file:packages/live-testspec",
        "live-web": "file:packages/live-web",
        "live-web-view": "file:packages/live-web-view",
        "live-web-edit": "file:packages/live-web-edit",
        "highlight.js": "^11.9.0",
        "highlightjs-line-numbers.js": "^2.8.0"
    }
}
