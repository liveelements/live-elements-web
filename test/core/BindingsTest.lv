import live-testspec

instance test Spec{
    Scenario{
        name: 'Nested Property Test'
        run: (expect) => {
            var data = BaseElement{
                var x: 100
                var y: this.x
            }
            data.x = 200
            expect(data.y).toBe(200)
        }
    }

    Scenario{
        name: 'Nested Property Test'
        run: (expect) => {
            var data = BaseElement{
                var x: BaseElement{
                    var z: 30
                }
                var y: this.x.z + 100
            }
            data.x.z = 130
            expect(data.y).toBe(230)

            data.x = BaseElement{
                var z: 1000
            }
            expect(data.y).toBe(1100)
            data.x.z = 300
            expect(data.y).toBe(400)
        }
    }

    Scenario{
        name: 'Nested Nested Property Test'
        run: (expect) => {
            var data = BaseElement{
                var x: BaseElement{
                    var y: BaseElement{
                        var z: 100
                    }
                }
                var t: this.x.y.z + 100
            }
            expect(data.t).toBe(200)
            data.x.y.z = 130

            expect(data.t).toBe(230)

            data.x = BaseElement{
                var y: BaseElement{
                    var z: 1000
                }
            }
            expect(data.t).toBe(1100)
            data.x.y.z = 300
            expect(data.t).toBe(400)
        }
    }

    Scenario{
        name: 'Null initial element assignment'
        run: (expect) => {
            component User < BaseElement{
                any name: '123'
            };

            component UserView < BaseElement{
                any user: null
                any userName: this.user ? this.user.name : null
            };

            let userView = UserView{ user: User{} }
            expect(userView.userName).toBe('123')
            userView.user.name = '345'
            expect(userView.userName).toBe('345')

            userView.user = null
            expect(userView.userName).toBe(null)

            userView.user = User{}
            userView.user.name = '345'
            expect(userView.userName).toBe('345')
        }
    }

    
    Scenario{
        name: 'Setter'
        run: (expect) => {
            let setterCount = 0
            component User{
                string value: '100'
                string boundValue: this.value
                set boundValue: (val:string){
                    ++setterCount
                    BaseElement.setProperty(this, 'boundValue', val)
                }
            };

            const user = User{}
            user.value = '300'
            expect(setterCount).toBe(1)
            expect(user.boundValue).toBe('300')
            user.boundValue = '400'
            expect(setterCount).toBe(2)
            expect(user.boundValue).toBe('400')
        }
    }
}
