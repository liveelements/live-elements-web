import live-testspec

instance test Spec{
    Scenario{
        name: 'timing test'
        run: (expect) => {
            var data = BaseElement{
                var x: 100
                var y: 200
                on xChanged : () => {
                    this.y = 300
                }
            }
            data.x = 130
            expect(data.y).toBe(300)
        }
    }
}
